{
  "buildCommand": "npm run build",
  "outputDirectory": ".output/public",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    }
  ],
  "env": {
    "VITE_SUPABASE_URL": "@supabase_url",
    "VITE_SUPABASE_ANON_KEY": "@supabase_anon_key",
    "VITE_GOOGLE_CALENDAR_API_KEY": "@google_calendar_api_key",
    "VITE_BOOKING_COM_API_KEY": "@booking_com_api_key",
    "VITE_WHATSAPP_API_KEY": "@whatsapp_api_key"
  }
}
