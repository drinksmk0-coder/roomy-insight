# Supabase
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Calendar
VITE_GOOGLE_CALENDAR_API_KEY=your_google_calendar_api_key
VITE_GOOGLE_CLIENT_ID=your_google_client_id
VITE_GOOGLE_CLIENT_SECRET=your_google_client_secret

# Gmail (via Supabase Edge Functions)
SUPABASE_GMAIL_EMAIL=your_gmail@gmail.com
SUPABASE_GMAIL_APP_PASSWORD=your_app_password

# Booking.com
VITE_BOOKING_COM_API_KEY=your_booking_com_api_key
VITE_BOOKING_COM_API_URL=https://secure-supply-connect.booking.com/hotels/ota

# WhatsApp (Twilio or similar)
VITE_WHATSAPP_API_KEY=your_whatsapp_api_key
VITE_WHATSAPP_ACCOUNT_SID=your_account_sid
VITE_WHATSAPP_PHONE_NUMBER=+5511999999999
